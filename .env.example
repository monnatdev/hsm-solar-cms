# ── Database ──────────────────────────────────────────────────
DATABASE_URL=mongodb://127.0.0.1/cms

# ── Payload ───────────────────────────────────────────────────
PAYLOAD_SECRET=YOUR_SECRET_HERE
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# ── Frontend (for CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Cloudflare R2 (leave blank in local dev → uses local disk) ─
S3_BUCKET=hsm-solar-cms
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto
